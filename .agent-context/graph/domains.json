    "class-schedule": {
      "label": "Class Scheduling",
      "cohesion": 0.72,
      "entities": {
        "screens": ["class-schedule", "class-calendar", "class-calendar-v1", "cancelled-classes", "reschedules", "student-teacher-classSchedules"],
