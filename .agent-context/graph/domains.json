    "dashboard": {
      "label": "Admin Dashboard & Analytics",
      "cohesion": 0.88,
      "entities": {
        "screens": ["admin-dashboard", "admin-ongoingClasses"],
        "components": ["admin-dashboard/*", "admin-ongoingclasses/*"],
        "services": ["analytics.ts"],
        "types": ["analytics.types.ts"]
      },
      "crossDomainRisk": "Dashboard reads from all domains (sessions, enrollments, users)"
    }
  }
}
